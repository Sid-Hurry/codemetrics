# Server Configurations
PORT=5000
NODE_ENV=development

# MySQL Database Configurations
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your_mysql_root_password
DB_NAME=codemetrics
DB_PORT=3306

# Optional: GitHub Personal Access Token to increase API rate limit (60 -> 5000 req/hr)
